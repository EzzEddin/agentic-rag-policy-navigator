# ─── aiXplain ────────────────────────────────────────────────────────────────
# Your aiXplain API key – get it from https://console.aixplain.com/
AIXPLAIN_API_KEY=your_aixplain_api_key_here

# (Optional) Pre-created agent ID – skips agent creation on startup.
# Set this after running scripts/setup_agent.py for the first time.
AGENT_ID=

# (Optional) Pre-created aiR index ID – skips index creation on startup.
# Set this after running scripts/setup_index.py for the first time.
# The index is backed by aiXplain aiR (integration: 6904bcf672a6e36b68bb72fb).
POLICY_INDEX_ID=

# (Optional) Override the default LLM used by the agents (GPT-4o by default).
DEFAULT_LLM_ID=6646261c6eb563165658bbb1

# ─── CourtListener ───────────────────────────────────────────────────────────
# Free API token from https://www.courtlistener.com/sign-in/
# Leave empty to use unauthenticated access (lower rate limits).
COURT_LISTENER_TOKEN=

# ─── Server ──────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_ITERATIONS=10
MAX_TOKENS=3072
